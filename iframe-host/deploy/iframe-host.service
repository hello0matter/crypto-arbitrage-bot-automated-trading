[Unit]
Description=Constrained iframe host
After=network.target

[Service]
Type=simple
User=iframehost
Group=iframehost
WorkingDirectory=/opt/iframe-host
EnvironmentFile=/etc/iframe-host/iframe-host.env
ExecStart=/usr/bin/node /opt/iframe-host/server.js
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/iframe-host

[Install]
WantedBy=multi-user.target
