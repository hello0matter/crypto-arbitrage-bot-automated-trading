{
  "version": 2,
  "port": 3030,
  "bind_host": "127.0.0.1",
  "admin_path": "admin",
  "admin_username": "admin",
  "admin_password": "CHANGE-ME-TO-A-STRONG-PASSWORD",
  "audit_max_body_bytes": 1048576,
  "sites": [
    {
      "id": "docs",
      "name": "Documentation",
      "enabled": true,
      "target_url": "https://docs.example.com/",
      "proxy_prefix": "/internal-content",
      "replace_rules": [
        {
          "comment": "Example: redirect a download to a controlled file",
          "pattern": "https://docs.example.com/launcher.exe",
          "replacement": "https://your-server.com/file.exe",
          "mode": "literal"
        },
        {
          "comment": "Example: strip a referral parameter via regex",
          "pattern": "[?&]ref=[^&\"']+",
          "replacement": "",
          "mode": "regex"
        }
      ],
      "oauth_bypass_paths": [
        "/auth/callback",
        "/oauth/redirect"
      ],
      "rewrite_request_headers": true,
      "audit_probe": {
        "enabled": false
      }
    }
  ]
}
